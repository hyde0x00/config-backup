#!/bin/bash

show_hidden=false
exact_match=false
match_filenames=false
show_preview=false
vertical_split=false
quiet=false

ignore=()
find_names=()

grep_opts=()

while getopts "aefpcwi:n:PVq" opt; do
  case "$opt" in
    a) show_hidden=true ;;
    e) exact_match=true ;;
    f) match_filenames=true ;;
    p) print_result=true ;;
    c) grep_opts+=("--ignore-case") ;;
    w) grep_opts+=("--word-regexp") ;;
    i) ignore+=("$OPTARG") ;;
    n) find_names+=("$OPTARG") ;;
    P) show_preview=true ;;
    V) show_preview=true && vertical_split=true ;;
    q) quiet=true ;;
    *) exit 1 ;;
  esac
done 2>/dev/null

shift $((OPTIND-1))

fzf_opts=()

[ "$show_preview" == "false" ] && fzf_opts+=("--preview-window=hidden")
[ "$vertical_split" == "true" ] && fzf_opts+=("--preview-window=right")
[ "$exact_match" == "true" ] && fzf_opts+=("--exact")
[ "$match_filenames" == "false" ] && fzf_opts+=("-d" ":" "-n" "3..")

pattern="$1"
shift

if [ -z "$1" ]; then
  set -- '.'
fi

for path in "$@"; do
  if [ "$quiet" != "true" ] && [ ! -e "$path" ]; then
    echo "'$path': No such file or directory" >&2
  fi
done

trim_slash() {
  echo "$1" | sed 's/\/\+/\//g; s/\/$//; s/^$/\//'
}

get_find_opts() {
  for x in "${ignore[@]}"; do
    last="${x:0-1}"
    if [ "$last" == "/" ]; then
      not_dirs=("-not" "-path" "$1/$(trim_slash "$x")*")
    else
      not_names+=("-not" "-name" "$x")
    fi
  done

  for x in "${find_names[@]}"; do
    if [ "${#find_names[@]}" -gt 1 ]; then
      names+=("-o")
    fi
    names+=("-name" "$x")
  done

  find_opts=("${not_dirs[@]}" "${not_names[@]}" "${names[@]}")
}

get_filenames() {
  get_find_opts "$1"

  if [ "$show_hidden" != "true" ]; then
    find -L "$1" -type f "${find_opts[@]}" -not -path "$1/.*" -not -path "$1*/.*" -print0 | sort
  else
    find -L "$1" -type f "${find_opts[@]}" -print0 | sort
  fi
}

sel="$(
  for path in "$@"; do
    get_filenames "$(trim_slash "$path")" | xargs -0 grep -nHIs "${grep_opts[@]}" -- "$pattern"
  done 2>/dev/null | sed 's/^\.\///' | ifne fzf "${fzf_opts[@]}" --preview='__fzf_search_preview {}'
)"

if [ -z "$sel" ]; then
  exit 1
fi

IFS=':' read -r file line text <<< "$sel"

if [ "$print_result" != "true" ]; then
  $EDITOR +"$line" "$file"
else
  echo "$sel"
fi
